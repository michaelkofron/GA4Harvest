# Path to your Google service account credentials JSON file.
# Only needed if you are NOT placing the file in backend/.
# If a .json file exists in backend/, it is auto-detected — no config needed.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-credentials.json

# Optional: enable password protection for the web UI.
# Set both to require a password on login.
# AUTH_ENABLED=true
# ADMIN_PASSWORD=your-password-here

# Set to true when serving over HTTPS (marks the session cookie as secure).
# Leave unset or false for localhost / plain HTTP.
# SECURE_COOKIES=true
