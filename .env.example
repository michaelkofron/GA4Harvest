# ── Credentials ───────────────────────────────────────────────────────────────

# Option A (recommended for containers/Railway/Render):
# Paste the full contents of your service account JSON key as a single env var.
# The key is parsed in memory and never written to disk.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Option B: point to a credentials file anywhere on disk.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-credentials.json

# Option C (simplest for local dev): drop your .json key file into backend/.
# It is auto-detected — no config needed. All .json files there are gitignored.

# ── Auth ──────────────────────────────────────────────────────────────────────

# Optional: enable password protection for the web UI.
# AUTH_ENABLED=true
# ADMIN_PASSWORD=your-password-here

# Set to true when serving over HTTPS (marks the session cookie as secure).
# Leave unset or false for localhost / plain HTTP.
# SECURE_COOKIES=true
